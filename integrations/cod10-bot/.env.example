# =============================================================================
# OpenWA ↔ Codigo 10 — Configuración del webhook
# =============================================================================
# El bot vive en la plataforma Cod10 (Next.js → cod10.vercel.app)
# Lee productos de MongoDB vía GraphQL Enatega + pagos desde BCV API

OPENWA_BASE_URL=https://tu-servidor-openwa.com
OPENWA_API_KEY=owa_tu_api_key
OPENWA_SESSION_ID=uuid-sesion-codigo10

# URL pública de Cod10 en Vercel
COD10_VERCEL_URL=https://cod10.vercel.app

# Mismo secreto configurado en Vercel (WEBHOOK_SECRET) y al registrar el webhook
WEBHOOK_SECRET=genera-un-secreto-largo
